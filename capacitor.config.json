{
  "appId": "com.mandoobeen.app",
  "appName": "نظام المندوبين",
  "webDir": "dist/public",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#9b2d6b",
      "showSpinner": true,
      "spinnerColor": "#ffffff",
      "androidSpinnerStyle": "small"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#9b2d6b"
    }
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
